# MotherDuck connection string. Omit (or use ":memory:") for local dev against
# a scratch in-memory DB; see SETUP.md for how to provision the real one.
DUCKDB_DATABASE_URL=md:strava_dashboard?motherduck_token=

# Strava API application credentials (developers.strava.com).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Any random string — Strava echoes this back during webhook subscription
# verification; the route handler checks it matches.
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Password gating the whole dashboard (see src/proxy.ts).
SITE_PASSWORD=

# Secret used to sign the session cookie proxy.ts checks. Any long random
# string — generate with `openssl rand -hex 32`.
SESSION_SECRET=
